---
const phone = "(307) 331-7552";
const phoneHref = "tel:+13073317552";
const email = "chase@twisted-air.com";
const address = "551.5 E Oak St, Wheatland, WY 82201";
const mapUrl = "https://www.google.com/maps/search/?api=1&query=551.5+E+Oak+St+Wheatland+WY+82201";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Twisted Air - Wheatland, WY's own Chase Proctor. Heating, cooling & plumbing done right by someone who grew up here. Call (307) 331-7552." />
    <meta name="keywords" content="HVAC, heating, cooling, plumbing, Wheatland, Wyoming, air conditioning, furnace, repair, installation" />
    <title>Twisted Air | Heating, Cooling & Plumbing | Wheatland, WY</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Header -->
    <header id="top">
      <div class="header-inner">
        <a href="#top" class="logo-link">
          <img src="/images/logo.png" alt="Twisted Air logo" class="logo" />
          <span class="logo-text">Twisted Air</span>
        </a>
        <nav>
          <a href="#services">Services</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
          <a href={phoneHref} class="nav-phone">{phone}</a>
        </nav>
        <button class="mobile-toggle" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <!-- Mobile Nav -->
    <div class="mobile-nav">
      <a href="#services">Services</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
      <a href={phoneHref} class="nav-phone">{phone}</a>
    </div>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-content">
        <h1>Fast, Honest HVAC & Plumbing<br />Service in Platte County</h1>
        <p class="hero-sub">When your furnace quits in January, your AC dies in July, or your pipes burst at midnight — you want a local crew who picks up the phone and gets it done. That's Twisted Air, right here in Wheatland, WY.</p>
        <div class="hero-actions">
          <a href={phoneHref} class="btn btn-primary">Call Us: {phone}</a>
          <a href="#about" class="btn btn-outline">Why Twisted Air</a>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="services">
      <div class="container">
        <h2>What We Do</h2>
        <p class="section-sub">Heating, cooling, and plumbing — all under one roof. One call handles it.</p>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v10"/><path d="M18.5 8a6.5 6.5 0 1 1-13 0"/><path d="M12 16v6"/><path d="M8 22h8"/><circle cx="12" cy="12" r="0" fill="currentColor"><animate attributeName="r" values="0;2;0" dur="2s" repeatCount="indefinite"/></circle><path d="M7 2l5 5 5-5" stroke-opacity="0.4"/></svg>
            </div>
            <h3>Heating</h3>
            <p>Wyoming winters don't wait, and neither do we. If your furnace goes down, our crew is on it.</p>
            <ul>
              <li>Furnace repair & installation</li>
              <li>Heat pump systems</li>
              <li>Seasonal tune-ups</li>
              <li>Emergency service</li>
            </ul>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 0 0-5 5v4a5 5 0 0 0 10 0V7a5 5 0 0 0-5-5z" stroke-opacity="0.3"/><path d="M4 14h2"/><path d="M18 14h2"/><path d="M12 18v4"/><path d="M8 22h8"/><path d="M9 6l6 6"/><path d="M15 6l-6 6"/><path d="M12 2v2"/><path d="M6.3 6.3l1.4 1.4"/><path d="M17.7 6.3l-1.4 1.4"/></svg>
            </div>
            <h3>Cooling</h3>
            <p>Summer heat hits Wheatland hard. We'll keep your home cool so you don't have to think about it.</p>
            <ul>
              <li>AC installation & repair</li>
              <li>Central air systems</li>
              <li>Ductwork services</li>
              <li>Indoor air quality</li>
            </ul>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
            </div>
            <h3>Plumbing</h3>
            <p>Leaky faucet or a full re-pipe — no job too small, no job too big. We show up and fix it.</p>
            <ul>
              <li>Leak detection & repair</li>
              <li>Water heater services</li>
              <li>Pipe installation & repair</li>
              <li>Drain cleaning</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="about">
      <div class="container">
        <div class="about-content">
          <div class="about-photo-placeholder" id="owner-photo">
            <!-- Owner photo will go here -->
          </div>
          <h2>About Twisted Air</h2>
          <p>Twisted Air was started by Chase Proctor — born and raised right here in Wheatland. He built a team of guys who share the same mindset: show up on time, do the job right, and charge a fair price.</p>
          <p>When you call Twisted Air, you're calling a local crew who lives down the road, shows up when they say they will, and won't bill you for work you don't need.</p>
          <div class="about-highlights">
            <div class="highlight">
              <strong>Wheatland Raised</strong>
              <span>Born here, lives here, works here</span>
            </div>
            <div class="highlight">
              <strong>Shows Up</strong>
              <span>On time, every time</span>
            </div>
            <div class="highlight">
              <strong>Straight Shooter</strong>
              <span>Honest quote before any work starts</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="cta">
      <div class="container">
        <h2>Furnace Down? Pipe Leaking? Don't Wait.</h2>
        <p>Call Twisted Air directly. No phone trees, no runaround.</p>
        <a href={phoneHref} class="btn btn-primary btn-lg">Call {phone}</a>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="contact">
      <div class="container">
        <h2>Contact Us</h2>
        <div class="contact-grid">
          <div class="contact-info">
            <div class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div>
                <strong>Phone</strong>
                <a href={phoneHref}>{phone}</a>
              </div>
            </div>
            <div class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <div>
                <strong>Email</strong>
                <a href={`mailto:${email}`}>{email}</a>
              </div>
            </div>
            <div class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <strong>Address</strong>
                <a href={mapUrl} target="_blank" rel="noopener noreferrer">{address}</a>
              </div>
            </div>
          </div>
          <div class="contact-map">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2984.5!2d-104.9533!3d42.0537!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDAzJzEzLjMiTiAxMDTCsDU3JzExLjkiVw!5e0!3m2!1sen!2sus!4v1700000000000"
              width="100%"
              height="300"
              style="border:0; border-radius: 12px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Twisted Air location"></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="container">
        <div class="footer-inner">
          <div class="footer-brand">
            <img src="/images/logo.png" alt="Twisted Air" class="footer-logo" />
            <span>Twisted Air</span>
          </div>
          <p class="footer-tagline">Heating, Cooling & Plumbing &middot; Wheatland, WY</p>
          <p class="footer-copy">&copy; {new Date().getFullYear()} Twisted Air. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <style>
      /* ===== Reset & Base ===== */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --blue-900: #0a2540;
        --blue-700: #0d4f8b;
        --blue-600: #1472b8;
        --blue-500: #1a8fe0;
        --blue-400: #3aa5f0;
        --blue-100: #e8f4fd;
        --blue-50: #f0f8ff;
        --gray-900: #1a1a2e;
        --gray-700: #4a4a5a;
        --gray-500: #6b7280;
        --gray-300: #d1d5db;
        --gray-100: #f3f4f6;
        --white: #ffffff;
        --radius: 12px;
        --shadow: 0 4px 24px rgba(0,0,0,0.08);
        --shadow-lg: 0 8px 40px rgba(0,0,0,0.12);
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: var(--gray-900);
        line-height: 1.6;
        background: var(--white);
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
      }

      a {
        color: var(--blue-600);
        text-decoration: none;
        transition: color 0.2s;
      }

      a:hover { color: var(--blue-500); }

      /* ===== Header ===== */
      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--gray-100);
      }

      .header-inner {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
      }

      .logo-link {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--gray-900);
        font-weight: 700;
        font-size: 1.25rem;
      }

      .logo-link:hover { color: var(--gray-900); }

      .logo {
        height: 44px;
        width: auto;
      }

      nav {
        display: flex;
        align-items: center;
        gap: 32px;
      }

      nav a {
        color: var(--gray-700);
        font-weight: 500;
        font-size: 0.95rem;
      }

      nav a:hover { color: var(--blue-600); }

      nav .nav-phone {
        background: var(--blue-600);
        color: var(--white);
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
      }

      nav .nav-phone:hover {
        background: var(--blue-500);
        color: var(--white);
      }

      .mobile-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }

      .mobile-toggle span {
        width: 24px;
        height: 2px;
        background: var(--gray-900);
        border-radius: 2px;
        transition: 0.2s;
      }

      .mobile-nav {
        display: none;
        position: fixed;
        top: 72px;
        left: 0;
        right: 0;
        background: var(--white);
        border-bottom: 1px solid var(--gray-100);
        z-index: 99;
        flex-direction: column;
        padding: 16px 24px;
        gap: 16px;
      }

      .mobile-nav.open { display: flex; }

      .mobile-nav a {
        color: var(--gray-700);
        font-weight: 500;
        font-size: 1.1rem;
        padding: 8px 0;
      }

      .mobile-nav .nav-phone {
        background: var(--blue-600);
        color: var(--white);
        padding: 12px;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
      }

      /* ===== Hero ===== */
      .hero {
        padding: 160px 24px 100px;
        background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-700) 50%, var(--blue-600) 100%);
        text-align: center;
        color: var(--white);
      }

      .hero-content {
        max-width: 720px;
        margin: 0 auto;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.25rem);
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 20px;
      }

      .hero-sub {
        font-size: 1.2rem;
        opacity: 0.9;
        margin-bottom: 36px;
        line-height: 1.5;
      }

      .hero-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
      }

      /* ===== Buttons ===== */
      .btn {
        display: inline-block;
        padding: 14px 28px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.2s;
        cursor: pointer;
        border: 2px solid transparent;
      }

      .btn-primary {
        background: var(--blue-500);
        color: var(--white);
        border-color: var(--blue-500);
      }

      .btn-primary:hover {
        background: var(--blue-400);
        border-color: var(--blue-400);
        color: var(--white);
      }

      .btn-outline {
        background: transparent;
        color: var(--white);
        border-color: rgba(255,255,255,0.4);
      }

      .btn-outline:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.7);
        color: var(--white);
      }

      .btn-lg {
        padding: 16px 36px;
        font-size: 1.15rem;
      }

      /* ===== Services ===== */
      .services {
        padding: 100px 0;
        background: var(--white);
      }

      .services h2, .about h2, .contact h2, .cta h2 {
        font-size: 2rem;
        font-weight: 800;
        text-align: center;
        margin-bottom: 12px;
      }

      .section-sub {
        text-align: center;
        color: var(--gray-500);
        font-size: 1.1rem;
        margin-bottom: 48px;
        max-width: 540px;
        margin-left: auto;
        margin-right: auto;
      }

      .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }

      .service-card {
        background: var(--white);
        border: 1px solid var(--gray-100);
        border-radius: var(--radius);
        padding: 36px 28px;
        transition: box-shadow 0.3s, transform 0.3s;
      }

      .service-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-4px);
      }

      .service-icon {
        color: var(--blue-600);
        margin-bottom: 20px;
      }

      .service-card h3 {
        font-size: 1.35rem;
        font-weight: 700;
        margin-bottom: 12px;
      }

      .service-card p {
        color: var(--gray-500);
        margin-bottom: 16px;
        line-height: 1.6;
      }

      .service-card ul {
        list-style: none;
        padding: 0;
      }

      .service-card li {
        padding: 6px 0;
        padding-left: 20px;
        position: relative;
        color: var(--gray-700);
        font-size: 0.95rem;
      }

      .service-card li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 14px;
        width: 8px;
        height: 8px;
        background: var(--blue-500);
        border-radius: 50%;
      }

      /* ===== About ===== */
      .about {
        padding: 100px 0;
        background: var(--gray-100);
      }

      .about-content {
        max-width: 700px;
        margin: 0 auto;
        text-align: center;
      }

      .about-photo-placeholder {
        display: none;
      }

      .about-photo {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 auto 24px;
        border: 4px solid var(--blue-500);
        display: block;
      }

      .about-content p {
        color: var(--gray-700);
        font-size: 1.1rem;
        margin-bottom: 16px;
        line-height: 1.7;
      }

      .about-highlights {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-top: 40px;
      }

      .highlight {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .highlight strong {
        font-size: 1.15rem;
        color: var(--blue-600);
      }

      .highlight span {
        color: var(--gray-500);
        font-size: 0.9rem;
      }

      /* ===== CTA ===== */
      .cta {
        padding: 80px 0;
        background: linear-gradient(135deg, var(--blue-700), var(--blue-600));
        text-align: center;
        color: var(--white);
      }

      .cta h2 { color: var(--white); margin-bottom: 12px; }
      .cta p { opacity: 0.9; font-size: 1.1rem; margin-bottom: 28px; }

      /* ===== Contact ===== */
      .contact {
        padding: 100px 0;
        background: var(--white);
      }

      .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        margin-top: 48px;
        align-items: start;
      }

      .contact-info {
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .contact-item {
        display: flex;
        gap: 16px;
        align-items: flex-start;
      }

      .contact-item svg {
        flex-shrink: 0;
        color: var(--blue-600);
        margin-top: 2px;
      }

      .contact-item strong {
        display: block;
        margin-bottom: 2px;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--gray-500);
      }

      .contact-item a {
        font-size: 1.05rem;
        color: var(--gray-900);
        font-weight: 500;
      }

      .contact-item a:hover { color: var(--blue-600); }

      /* ===== Footer ===== */
      footer {
        background: var(--gray-900);
        color: var(--gray-300);
        padding: 48px 0;
      }

      .footer-inner {
        text-align: center;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 8px;
      }

      .footer-brand span {
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--white);
      }

      .footer-logo {
        height: 36px;
        width: auto;
      }

      .footer-tagline {
        color: var(--gray-500);
        margin-bottom: 16px;
      }

      .footer-copy {
        color: var(--gray-500);
        font-size: 0.85rem;
      }

      /* ===== Responsive ===== */
      @media (max-width: 768px) {
        nav { display: none; }
        .mobile-toggle { display: flex; }

        .services-grid {
          grid-template-columns: 1fr;
        }

        .about-highlights {
          grid-template-columns: 1fr;
          gap: 16px;
        }

        .contact-grid {
          grid-template-columns: 1fr;
        }

        .hero {
          padding: 140px 24px 80px;
        }
      }
    </style>

    <script>
      const toggle = document.querySelector('.mobile-toggle');
      const mobileNav = document.querySelector('.mobile-nav');

      toggle?.addEventListener('click', () => {
        mobileNav?.classList.toggle('open');
      });

      // Close mobile nav when clicking a link
      mobileNav?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileNav.classList.remove('open');
        });
      });
    </script>
  </body>
</html>
